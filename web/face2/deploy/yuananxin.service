[Unit]
Description=Yuan An Xin OneNET IoT prototype
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/yuananxin
ExecStart=/usr/bin/node /opt/yuananxin/server.js
Restart=always
RestartSec=3
Environment=NODE_ENV=production
Environment=HOST=0.0.0.0
Environment=PORT=3000

[Install]
WantedBy=multi-user.target
